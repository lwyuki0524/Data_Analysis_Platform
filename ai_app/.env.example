"""
LLM_MODE:
Select the LLM method to use.
Optional values:
- "local": Use a local model (local LLM)
- "openai": Use an OpenAI cloud model

Required settings for different modes:
local (local):
- MODEL: The name of the model to use
- BASE_URL: The API location of the local LLM service (e.g., Ollama / vLLM / self-hosted server)

openai (cloud):
- LLM_API_KEY: The OpenAI API key
- MODEL: The name of the model to use (e.g., gpt-4.1-mini, etc.)
"""
LLM_MODE="local"
BASE_URL="YOUR_LLM_LOCAL_URL"
MODEL="YOUR_LLM_NAME"
LLM_API_KEY="YOUR_LLM_API_KEY"